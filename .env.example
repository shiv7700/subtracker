# SubTracker environment variables.
# Copy this file to .env.local and fill in real values:  cp .env.example .env.local
# .env.local is gitignored — never commit real keys.

# ── Supabase ───────────────────────────────────────────────────────────────
# From Supabase dashboard → Project Settings → API.

# Project URL (looks like https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Public "anon" key — safe to expose to the browser (RLS protects the data).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret "service_role" key — SERVER ONLY. Bypasses RLS so the cron can read
# every user's due subscriptions. NEVER expose this to the browser / client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Cron ───────────────────────────────────────────────────────────────────
# A secret you invent. Protects /api/check-reminders so only Vercel Cron (and
# you, with the secret) can trigger reminders. Use a long random string.
# Generate one with:  openssl rand -hex 32
CRON_SECRET=

# ── Twilio WhatsApp (PRIMARY channel — what we actually use) ────────────────
# notify() auto-routes here whenever all four TWILIO_* vars are set.
# Get them from the Twilio Console after joining the WhatsApp sandbox:
#   Console home → Account SID + Auth Token
#   Messaging → Try it out → Send a WhatsApp message → sandbox setup
# Sandbox note: message "join <code>" to TWILIO_FROM from your WhatsApp first;
# re-join if you've been silent for 24h (sandbox session window).

# Your Twilio Account SID (starts with "AC...").
TWILIO_ACCOUNT_SID=

# Your Twilio Auth Token (secret — server only, never expose to the browser).
TWILIO_AUTH_TOKEN=

# Sender number. For the sandbox this is Twilio's shared number:
TWILIO_FROM=+14155238886

# Destination number in E.164 format (with +). The number that joined the
# sandbox by messaging "join <code>" to TWILIO_FROM.
TWILIO_TO=+919876543210

# ── Meta WhatsApp Cloud API (OPTIONAL alternative — leave blank) ────────────
# Only used when the TWILIO_* vars above are NOT set. Requires a Meta for
# Developers account + an APPROVED message template.
# From Meta for Developers → your WhatsApp app → API Setup.

# Access token (Bearer) for the WhatsApp Cloud API.
WHATSAPP_TOKEN=

# The Phone Number ID of your WhatsApp sender (NOT the phone number itself).
WHATSAPP_PHONE_NUMBER_ID=

# Destination phone in international format, digits only (e.g. 919876543210).
WHATSAPP_TO=

# Name of your APPROVED message template (must have exactly one body var {{1}}).
WHATSAPP_TEMPLATE=

# Template language code — must match the language you created the template in
# (e.g. en_US, en_GB, en). Defaults to en_US if left blank.
WHATSAPP_TEMPLATE_LANG=en_US
