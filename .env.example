# SubTracker environment variables.
# Copy this file to .env.local and fill in real values:  cp .env.example .env.local
# .env.local is gitignored — never commit real keys.

# ── Supabase ───────────────────────────────────────────────────────────────
# From Supabase dashboard → Project Settings → API.

# Project URL (looks like https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Public "anon" key — safe to expose to the browser (RLS protects the data).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret "service_role" key — SERVER ONLY. Bypasses RLS so the cron can read
# every user's due subscriptions. NEVER expose this to the browser / client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Cron ───────────────────────────────────────────────────────────────────
# A secret you invent. Protects /api/check-reminders so only Vercel Cron (and
# you, with the secret) can trigger reminders. Use a long random string.
# Generate one with:  openssl rand -hex 32
CRON_SECRET=

# ── WhatsApp (Phase 5 — leave blank until you wire up Meta Cloud API) ───────
# From Meta for Developers → your WhatsApp app → API Setup.

# Access token (Bearer) for the WhatsApp Cloud API.
WHATSAPP_TOKEN=

# The Phone Number ID of your WhatsApp sender (NOT the phone number itself).
WHATSAPP_PHONE_NUMBER_ID=

# Destination phone in international format, digits only (e.g. 919876543210).
WHATSAPP_TO=

# Name of your APPROVED message template (must have exactly one body var {{1}}).
WHATSAPP_TEMPLATE=
